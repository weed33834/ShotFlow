# ShotFlow backend — environment variables example
#
# NOTE: backend reads the repo-root .env (configured in app/core/config.py via
# PROJECT_ROOT / ".env"), NOT this file. This file lists the backend-relevant
# variables for reference. To configure, edit the repo-root .env (see ../.env.example).

# ===== App =====
APP_NAME=ShotFlow API
APP_VERSION=0.2.0
API_V1_PREFIX=/api/v1
DEBUG=false
# Simulate mode: true = all generation services return mock output (no GPU needed)
SIMULATE_MODE=true

# ===== Database =====
# Production (docker-compose): uses POSTGRES_USER/PASSWORD/DB env vars to build URL
# Local dev:                  sqlite:///./shotflow.db
DATABASE_URL=postgresql+psycopg://shotflow:change-me-to-a-strong-password@postgres:5432/shotflow

# ===== Redis / Celery =====
# docker-compose uses REDIS_PASSWORD to build connection strings
REDIS_URL=redis://:change-me-to-a-strong-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:change-me-to-a-strong-redis-password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change-me-to-a-strong-redis-password@redis:6379/2

# ===== Security =====
# Generate with: openssl rand -hex 32
# Required in non-DEBUG mode (empty / placeholder / <32 chars will refuse to start)
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1

# ===== External services =====
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_DIR=${HOME}/ComfyUI
KLING_API_KEY=
KLING_BASE_URL=https://api.piapi.ai
ELEVENLABS_API_KEY=
SUNO_API_KEY=
SUNO_BASE_URL=https://api.sunoaiapi.com
