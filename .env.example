# ShotFlow — 环境变量示例
# 复制为 .env 并填入真实值：cp .env.example .env
# 注意：.env 文件已被 .gitignore 忽略，不会提交到仓库

# ===== 应用 =====
APP_NAME=ShotFlow API
APP_VERSION=0.2.0
API_V1_PREFIX=/api/v1
# 开发/本地默认开启 DEBUG：绕过 SECRET_KEY 启动守卫，实现 cp .env.example .env 后开箱即用。
# 生产部署务必改为 false 并设置下方的 SECRET_KEY（否则启动会被 _guard_secret_key 拦截）。
DEBUG=true
# 模拟模式：true = 所有生成 service 返回模拟结果，无需 GPU（开发/测试推荐）
# 生产 GPU 主机设为 false 以接入真实 ComfyUI / 可灵 / ElevenLabs / Suno
SIMULATE_MODE=true
# 当前环境是否具备本地 GPU。影响 video_i2v/video_t2v 的 provider 自动选择：
# 无 GPU 时仅候选云端 provider（kling/cogvideox），避免派发到本地 ComfyUI 后卡死。
# 生产 GPU 主机设 true；纯 CI / 无卡沙箱设 false。
HAS_GPU=false

# ===== 数据库 =====
# 开发/本地默认 SQLite（无需任何外部服务，开箱即用）。
# 生产用 PostgreSQL：取消注释下方 postgresql+psycopg://... 一行（docker-compose 亦会注入）。
DATABASE_URL=sqlite:///./shotflow.db
# 生产示例：DATABASE_URL=postgresql+psycopg://shotflow:change-me@postgres:5432/shotflow

# ===== Redis / Celery =====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== 安全 =====
# 生产部署必须替换为足够长的随机串，否则后端启动会被 _guard_secret_key 拦截。
# 生成: openssl rand -hex 32
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 跨域（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ===== 资产存储 =====
# 真实模式下生成资产落地于此目录下（按 task_id 隔离）
STORAGE_DIR=

# ===== ffmpeg =====
# ffmpeg 二进制路径，空则从 PATH 查找
FFMPEG_PATH=

# ===== ComfyUI =====
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_DIR=${HOME}/ComfyUI

# ===== LLM（Brain 脚本/分镜生成，多 Provider 适配）=====
# 认证 Key 统一走 LLM_API_KEY；base_url/model 未显式配置时按 LLM_PROVIDER 回落默认值。
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
# LLM provider: openai / deepseek / moonshot / ollama / gemini / claude
LLM_PROVIDER=

# ===== 编排器默认 Provider =====
IMAGE_PROVIDER=hunyuan_image
VIDEO_PROVIDER=wanx
ANCHOR_PROVIDER=hunyuan_image

# ===== 腾讯云 =====
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_TTS_APP_ID=

# ===== 阿里 DashScope（通义万相/千问）=====
DASHSCOPE_API_KEY=

# ===== 可灵 Kling =====
KLING_API_KEY=
KLING_BASE_URL=https://api.piapi.ai

# ===== 即梦（火山引擎 Ark，兼容 OpenAI 协议）=====
JIMENG_API_KEY=
JIMENG_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 可覆盖模型名（如指向其他 OpenAI 兼容网关时用 step-image-edit-2 等）
JIMENG_IMAGE_MODEL=
JIMENG_VIDEO_MODEL=

# ===== Runway =====
RUNWAY_API_KEY=

# ===== HeyGen（口型同步）=====
HEYGEN_API_KEY=

# ===== Suno（BGM）=====
SUNO_API_KEY=
SUNO_BASE_URL=https://api.sunoaiapi.com

# ===== Liblib（图，LoRA 生态）=====
LIBLIB_API_KEY=

# ===== NovelAI（动漫专精图）=====
NOVELAI_API_KEY=

# ===== 自动发布平台 =====
DOUYIN_ACCESS_TOKEN=
BILIBILI_SESSDATA=

# ===== 开源替代方案 =====
# ASR 语音转文字: funasr / whisper / openai / auto
ASR_PROVIDER=auto
# Real-ESRGAN 超分 CLI 路径（空则从 PATH 查找）
REALESRGAN_PATH=
# RIFE 帧插值 CLI 路径（空则从 PATH 查找）
RIFE_PATH=
# GPT-SoVITS 语音克隆 API 服务地址（本地部署）
GPTSOVITS_API_URL=
