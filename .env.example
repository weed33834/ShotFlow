# ShotFlow — 环境变量示例
# 复制为 .env 并填入真实值：cp .env.example .env
# 注意：.env 文件已被 .gitignore 忽略，不会提交到仓库

# ===== 应用 =====
APP_NAME=ShotFlow API
APP_VERSION=0.2.0
API_V1_PREFIX=/api/v1
# 开发/本地默认开启 DEBUG：绕过 SECRET_KEY 启动守卫，实现 cp .env.example .env 后开箱即用。
# 生产部署务必改为 false 并设置下方的 SECRET_KEY（否则启动会被 _guard_secret_key 拦截）。
DEBUG=true
# 模拟模式：true = 所有生成 service 返回模拟结果，无需 GPU（开发/测试推荐）
# 生产 GPU 主机设为 false 以接入真实 ComfyUI / 可灵 / ElevenLabs / Suno
SIMULATE_MODE=true
# 当前环境是否具备本地 GPU。影响 video_i2v/video_t2v 的 provider 自动选择：
# 无 GPU 时仅候选云端 provider（kling/cogvideox），避免派发到本地 ComfyUI 后卡死。
# 生产 GPU 主机设 true；纯 CI / 无卡沙箱设 false。
HAS_GPU=false

# ===== 数据库 =====
# 开发/本地默认 SQLite（无需任何外部服务，开箱即用）。
# 生产用 PostgreSQL：取消注释下方 postgresql+psycopg://... 一行（docker-compose 亦会注入）。
# docker-compose 会通过下面的变量自动拼接 DATABASE_URL
POSTGRES_USER=shotflow
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=shotflow
DATABASE_URL=sqlite:///./shotflow.db
# 生产示例：DATABASE_URL=postgresql+psycopg://shotflow:change-me-to-a-strong-password@postgres:5432/shotflow

# ===== Redis / Celery =====
# docker-compose 会通过 REDIS_PASSWORD 自动拼接连接字符串
REDIS_PASSWORD=change-me-to-a-strong-redis-password
REDIS_URL=redis://:change-me-to-a-strong-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:change-me-to-a-strong-redis-password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change-me-to-a-strong-redis-password@redis:6379/2

# ===== 安全 =====
# 生产部署必须替换为足够长的随机串，否则后端启动会被 _guard_secret_key 拦截。
# 生成: openssl rand -hex 32
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# 跨域（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ===== ComfyUI =====
COMFYUI_URL=http://127.0.0.1:8188
# ComfyUI 安装路径（preflight_check.py 使用，默认 ~/ComfyUI）
COMFYUI_DIR=${HOME}/ComfyUI

# ===== 可灵 API =====
KLING_API_KEY=
KLING_BASE_URL=https://api.piapi.ai

# ===== ElevenLabs 配音 =====
ELEVENLABS_API_KEY=

# ===== Suno 配乐（可选） =====
SUNO_API_KEY=
SUNO_BASE_URL=https://api.sunoaiapi.com
