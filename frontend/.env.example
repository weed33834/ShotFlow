# ShotFlow frontend — environment variables example
# Copy to .env.local:  cp frontend/.env.example frontend/.env.local
# Vite reads VITE_-prefixed vars at build/dev time.

# Backend API base URL. In dev, Vite proxies /api to this (see vite.config.ts),
# so the frontend code can call /api/... directly without setting this.
# Set this only if the backend is on a different origin in production.
VITE_API_BASE_URL=http://localhost:8000/api/v1
